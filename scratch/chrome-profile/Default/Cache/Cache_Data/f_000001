    <script>
        function setTheme(theme) {
            console.log('Force applying theme:', theme);
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('truthlens_theme', theme);

            // Sync with existing buttons if they exist
            const lightBtn = document.getElementById('theme-light-btn');
            const darkBtn = document.getElementById('theme-dark-btn');
            if (lightBtn && darkBtn) {
                if (theme === 'dark') {
                    darkBtn.classList.add('active');
                    lightBtn.classList.remove('active');
                } else {
                    lightBtn.classList.add('active');
                    darkBtn.classList.remove('active');
                }
            }
        }
        // Early load to prevent flicker
        const saved = localStorage.getItem('truthlens_theme') || 'light';
        document.documentElement.setAttribute('data-theme', saved);

        // --- Chat File Logic ---
        function triggerChatUpload() {
            console.log('Triggering chat upload...');
            document.getElementById('chat-file-input')?.click();
        }

        async function handleChatFileSelect(input) {
            const file = input.files[0];
            if (!file) return;

            console.log('File selected:', file.name);
            // We call the global app.js logic via a custom event or direct call
            if (window.truthLens_handleFileUpload) {
                window.truthLens_handleFileUpload(file);
            } else {
                console.error('App logic not loaded yet');
            }
        }
    </script>
