/* Pipeline Visualization */
.pipeline-viz {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
    background: white;
    padding: 2rem;
    border-radius: 24px;
    box-shadow: var(--shadow-soft);
}

.pipeline-viz.horizontal {
    flex-direction: row;
    justify-content: center;
}

.pv-step {
    padding: 1rem 2rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-main);
    min-width: 180px;
    text-align: center;
}

.pv-step.highlight {
    background: #e0f2fe;
    border-color: #3b82f6;
    color: #0284c7;
}

.pv-step.result {
    background: #fef2f2;
    border-color: #ef4444;
    color: #dc2626;
}

.pv-arrow {
    color: #cbd5e1;
    font-size: 1rem;
    animation: bounceDown 2s infinite;
}

.pipeline-viz.horizontal .pv-arrow {
    animation: bounceRight 2s infinite;
}

@keyframes bounceDown {

    0%,
    20%,
    50%,
    80%,
    100% {
        transform: translateY(0);
    }

    40% {
        transform: translateY(-5px);
    }

    60% {
        transform: translateY(-3px);
    }
}

@keyframes bounceRight {

    0%,
    20%,
    50%,
    80%,
    100% {
        transform: translateX(0);
    }

    40% {
        transform: translateX(5px);
    }

    60% {
        transform: translateX(3px);
    }
}

