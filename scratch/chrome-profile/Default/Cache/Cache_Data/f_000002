        localStorage.setItem('truthlens_user', JSON.stringify(demoUser));
        currentUser = demoUser;
        
        const demoRuns = [
            {
                id: "run-3",
                timestamp: Date.now() - 3600000 * 1,
                prompt: "What is the capital of Australia?",
                response: "The capital of Australia is Canberra, which was selected as a compromise between Sydney and Melbourne in 1908.",
                riskScore: 6,
                verdict: "High Trust",
                data: {
                    overall_risk: 0.06,
                    sentence_analysis: [
                        { category: 'verified', confidence: 0.98 },
                        { category: 'verified', confidence: 0.97 }
                    ]
                }
            },
            {
                id: "run-2",
                timestamp: Date.now() - 3600000 * 2,
                prompt: "Did Apple launch the Vision Pro in 2022?",
                response: "Apple announced the Vision Pro in June 2022 and released it in early 2023.",
                riskScore: 18,
                verdict: "High Trust",
                data: {
                    overall_risk: 0.18,
                    sentence_analysis: [
                        { category: 'weak', confidence: 0.74 },
                        { category: 'verified', confidence: 0.85 }
                    ]
                }
            },
            {
                id: "run-1",
                timestamp: Date.now() - 3600000 * 3,
                prompt: "Is BA.2.86 COVID variant highly mutated?",
                response: "BA.2.86 has over 30 mutations in its spike protein compared to BA.2, making it significantly different.",
                riskScore: 12,
                verdict: "High Trust",
                data: {
                    overall_risk: 0.12,
                    sentence_analysis: [
                        { category: 'verified', confidence: 0.95 },
                        { category: 'verified', confidence: 0.92 }
                    ]
                }
            }
        ];
        localStorage.setItem(`truthlens_runs_${demoUser.email}`, JSON.stringify(demoRuns));

        // Inject CSS for transparent background and hiding unnecessary panels for screenshot
        const style = document.createElement('style');
        style.textContent = `
            .navbar, .main-footer, .page-header, .status-pill, .db-grid-right, #db-hallucination-explain, #db-extra-widgets {
                display: none !important;
            }
            body, .view, #view-dashboard {
                background: transparent !important;
                background-color: transparent !important;
            }
            body {
                padding-top: 10px !important;
                margin: 0 !important;
                overflow: hidden !important;
            }
            #view-dashboard {
                padding: 10px !important;
                max-width: 800px !important;
                margin: 0 auto !important;
            }
            .dashboard-grid {
                grid-template-columns: 1fr !important;
                margin-bottom: 0 !important;
                margin-top: 0 !important;
            }
            .panel-card {
                margin-bottom: 10px !important;
            }
        `;
        document.head.appendChild(style);
    }

    // Check logout route first
    if (path === '/logout') {
        currentUser = null;
        localStorage.removeItem('truthlens_user');
        updateNavForAuth();
        window.location.href = '/';
        return;
    }

    // Protected route check
    const protectedPaths = ['/dashboard', '/settings'];
    const savedUser = localStorage.getItem('truthlens_user');
    if (protectedPaths.includes(path) && !savedUser) {
        localStorage.setItem('auth_redirect_error', 'Please log in to access this page.');
        window.location.href = '/login';
        return;
    }

    if (path === '/login') {
        const redirectErr = localStorage.getItem('auth_redirect_error');
        if (redirectErr) {
            const errEl = document.getElementById('auth-error');
            if (errEl) {
                errEl.textContent = redirectErr;
                errEl.classList.remove('hidden');
            }
            localStorage.removeItem('auth_redirect_error');
        }
    }

    if (path === '/dashboard') {
        updateDashboardUI();
    }
    if (path === '/analysis') {
        resetDashboard();
        const viewRunId = localStorage.getItem('view_run_id');
        if (viewRunId && currentUser) {
            localStorage.removeItem('view_run_id');
            const runs = JSON.parse(localStorage.getItem(`truthlens_runs_${currentUser.email}`) || '[]');
            const run = runs.find(r => r.id === viewRunId);
            if (run) {
                setTimeout(() => {
                    const promptInput = document.getElementById('db-prompt');
                    const responseInput = document.getElementById('db-response');
                    if (promptInput) promptInput.value = run.prompt;
                    if (responseInput) responseInput.value = run.response;
                    
                    setDbMode('own');
                    renderDashboardResults(run.data);
                }, 50);
            }
        }
    }
    if (path === '/settings' && currentUser) {
        const nameField = document.getElementById('setting-profile-name');
        const emailField = document.getElementById('setting-profile-email');
        if (nameField) nameField.value = currentUser.name || '';
        if (emailField) emailField.value = currentUser.email || '';
        
        const notifyEmail = document.getElementById('setting-notify-email');
        const notifySlack = document.getElementById('setting-notify-slack');
        const notifyConsole = document.getElementById('setting-notify-console');
        
        if (notifyEmail) notifyEmail.checked = localStorage.getItem('truthlens_notify_email') !== 'false';
        if (notifySlack) notifySlack.checked = localStorage.getItem('truthlens_notify_slack') === 'true';
        if (notifyConsole) notifyConsole.checked = localStorage.getItem('truthlens_notify_console') !== 'false';
    }

    if (path === '/chat' && typeof chatRenderSidebar === 'function') {
        chatRenderSidebar();
    }
}

