function getColorForRisk(value) {
    if (value < 0.3) return '#10b981';
    if (value < 0.6) return '#f59e0b';
    return '#ef4444';
}

function getRiskLabel(value) {
    if (value < 0.3) return 'Low Risk';
    if (value < 0.6) return 'Medium Risk';
    return 'High Risk';
}

async function callAPI(prompt, response, context = '') {
    const headers = { 'Content-Type': 'application/json' };
    if (currentUser && currentUser.token) {
        headers['Authorization'] = `Bearer ${currentUser.token}`;
    }
    const res = await fetch('/api/evaluate', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ prompt, response, context })
    });

    if (!res.ok) {
        if (res.status === 401) {
            alert('Your session has expired. Please log in again.');
            currentUser = null;
            localStorage.removeItem('truthlens_user');
            updateNavForAuth();
            navigateTo('login');
            throw new Error('Session expired');
        }
        const errData = await res.json().catch(() => ({ detail: 'Server Error' }));
        throw new Error(errData.detail || `API error (${res.status})`);
    }

    return res.json();
}

async function callGenerateAPI(prompt, model = 'tiny') {
    const headers = { 'Content-Type': 'application/json' };
    if (currentUser && currentUser.token) {
        headers['Authorization'] = `Bearer ${currentUser.token}`;
    }
    const res = await fetch('/api/generate', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ prompt, model })
    });
    if (res.status === 401) {
        alert('Your session has expired. Please log in again.');
        currentUser = null;
        localStorage.removeItem('truthlens_user');
        updateNavForAuth();
        navigateTo('login');
        throw new Error('Unauthorized');
    }
    const data = await res.json();
    return { response: data.generated_response, context: data.context || '' };
}

